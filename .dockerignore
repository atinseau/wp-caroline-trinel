# Version control
.git
.gitignore

# Environment files (injected at runtime, not baked into image)
.env
.env.*
!.env.example

# Dependencies (rebuilt in Docker build stage)
vendor/

# Development files
node_modules/
tests/
phpunit.xml
phpunit.xml.dist
.phpunit.cache
.phpunit.result.cache
pint.json

# Docker files (no need to copy themselves)
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore

# Documentation
AGENTS.md
README.md
LICENSE.md
CLAUDE.md

# IDE & OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# WordPress uploads (mounted as volume at runtime)
web/app/uploads/*

# Logs
*.log

# WP-CLI local config
wp-cli.local.yml

# Auth tokens
auth.json
