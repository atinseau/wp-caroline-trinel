# ==============================================================================
# Environment Configuration
# ==============================================================================
#
# For local development: run `make setup` (copies .env.development → .env)
# For production/staging: copy this file to .env and fill in all values.
#
# Documentation: see AGENTS.md → "Environment Setup"
# ==============================================================================

# ==============================================================================
# App
# ==============================================================================

WP_ENV=                               # development | staging | production
WP_HOME=                              # Full site URL (no trailing slash)
WP_SITEURL="${WP_HOME}/wp"            # WordPress core URL (do not change the /wp suffix)

# WP_DEBUG_LOG=                       # Optional: custom debug log path

# ==============================================================================
# Database
# ==============================================================================

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=                              # In Docker: use db:3306
DB_PREFIX='wp_'

# Alternative: use a DSN instead of individual DB_* variables
# When using DATABASE_URL, you can remove DB_NAME, DB_USER, DB_PASSWORD, DB_HOST
# DATABASE_URL=

# DB_SSL=true                         # Uncomment to enable SSL for the DB connection

# ==============================================================================
# Authentication Keys & Salts
# ==============================================================================
# Generate at: https://roots.io/salts.html
# Each key should be a unique, random string.

AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=

# ==============================================================================
# Optional
# ==============================================================================

# DISABLE_WP_CRON=true                # Disable WP-Cron (use a real cron job instead)
# WP_POST_REVISIONS=5                 # Limit the number of post revisions (default: unlimited)
